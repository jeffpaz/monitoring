{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Firewalla — SNMP interface monitoring via snmp-exporter if_mib",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Interface Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "bps",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "abs" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifHCInOctets{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m]) * 8",
          "legendFormat": "▲ {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifHCOutOctets{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m]) * 8",
          "legendFormat": "▼ {{ifDescr}}",
          "refId": "B"
        }
      ],
      "title": "Interface Throughput (bits/sec) — In ▲ / Out ▼",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "Bps",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 10 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifHCInUcastPkts{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m])",
          "legendFormat": "▲ {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifHCOutUcastPkts{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m])",
          "legendFormat": "▼ {{ifDescr}}",
          "refId": "B"
        }
      ],
      "title": "Unicast Packets/sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "pps",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifInErrors{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m])",
          "legendFormat": "In Err {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifOutErrors{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m])",
          "legendFormat": "Out Err {{ifDescr}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifInDiscards{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m])",
          "legendFormat": "In Drop {{ifDescr}}",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifOutDiscards{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}[2m])",
          "legendFormat": "Out Drop {{ifDescr}}",
          "refId": "D"
        }
      ],
      "title": "Errors & Discards/sec",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Interface Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "1": { "color": "green", "text": "up" }, "2": { "color": "red", "text": "down" }, "3": { "color": "yellow", "text": "testing" }, "7": { "color": "blue", "text": "lowerLayerDown" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 18 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": {},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ifOperStatus{instance=\"$instance\", ifDescr!~\"lo|ifb.*\"}",
          "legendFormat": "{{ifDescr}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Interface Operational Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Speed (Mbps)" },
            "properties": [{ "id": "unit", "value": "none" }]
          },
          {
            "matcher": { "id": "byName", "options": "Oper Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "1": { "color": "green", "text": "up" }, "2": { "color": "red", "text": "down" } }, "type": "value" }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 23 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ifHighSpeed{instance=\"$instance\", ifDescr!~\"ifb.*\"}",
          "legendFormat": "{{ifDescr}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ifOperStatus{instance=\"$instance\", ifDescr!~\"ifb.*\"}",
          "legendFormat": "{{ifDescr}}",
          "instant": true,
          "refId": "B",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ifMtu{instance=\"$instance\", ifDescr!~\"ifb.*\"}",
          "legendFormat": "{{ifDescr}}",
          "instant": true,
          "refId": "C",
          "format": "table"
        }
      ],
      "title": "Interface Details",
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "ifIndex": true },
            "renameByName": { "ifDescr": "Interface", "Value #A": "Speed (Mbps)", "Value #B": "Oper Status", "Value #C": "MTU" }
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 102,
      "title": "Collector Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 33 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "snmp_scrape_duration_seconds{instance=\"$instance\"}",
          "legendFormat": "Total scrape",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "snmp_scrape_walk_duration_seconds{instance=\"$instance\"}",
          "legendFormat": "Walk duration",
          "refId": "B"
        }
      ],
      "title": "SNMP Scrape Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5, "showPoints": "never" },
          "unit": "none",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 33 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "snmp_scrape_pdus_returned{instance=\"$instance\"}",
          "legendFormat": "PDUs returned",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "snmp_scrape_packets_sent{instance=\"$instance\"}",
          "legendFormat": "Packets sent",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "snmp_scrape_packets_retried{instance=\"$instance\"}",
          "legendFormat": "Retries",
          "refId": "C"
        }
      ],
      "title": "SNMP Packet Stats",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["snmp", "firewalla", "network"],
  "templating": {
    "list": [
      {
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(ifOperStatus{job=\"firewalla\"}, instance)",
        "hide": 0,
        "includeAll": false,
        "label": "Device",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": {
          "query": "label_values(ifOperStatus{job=\"firewalla\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Firewalla — SNMP",
  "uid": "firewalla-snmp",
  "version": 1
}
